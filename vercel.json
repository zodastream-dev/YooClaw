{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/p/:slug", "destination": "https://api.yookeer.com/p/:slug" },
    { "source": "/game/:slug", "destination": "https://api.yookeer.com/game/:slug" },
    { "source": "/web/:slug", "destination": "https://api.yookeer.com/web/:slug" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
